<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="auth.PerfilController"
            style="-fx-background-color: #f1f5f9;">

    <top>
        <HBox styleClass="app-header" alignment="CENTER_LEFT" spacing="16">
            <Label text="Sistema de Doação" styleClass="app-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="labelUsuarioHeader" styleClass="app-user-pill"/>
        </HBox>
    </top>

    <center>
        <StackPane styleClass="page-bg">
            <VBox styleClass="card" maxWidth="480" maxHeight="-Infinity"
                  spacing="20" alignment="TOP_LEFT">
                <padding>
                    <Insets top="32" right="32" bottom="32" left="32"/>
                </padding>

                <VBox spacing="6">
                    <Label text="Editar Perfil" styleClass="h1"/>
                    <Label text="Atualize seu nome de usuário ou senha."
                           styleClass="label-muted"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Novo nome de usuário" styleClass="caption"/>
                    <TextField fx:id="campoNovoNome"
                               styleClass="input-field"
                               promptText="Novo nome de usuário"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Senha atual (obrigatória)" styleClass="caption"/>
                    <PasswordField fx:id="campoSenhaAtual"
                                   styleClass="input-field"
                                   promptText="Digite sua senha atual"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Nova senha (opcional — em branco mantém atual)"
                           styleClass="caption"/>
                    <PasswordField fx:id="campoNovaSenha"
                                   styleClass="input-field"
                                   promptText="Nova senha"/>
                </VBox>

                <Label fx:id="labelMensagem" wrapText="true"/>

                <HBox spacing="12" alignment="CENTER">
                    <Button text="Voltar"
                            styleClass="btn-secondary"
                            onAction="#onClickVoltar"
                            cancelButton="true"
                            HBox.hgrow="ALWAYS"
                            maxWidth="Infinity"/>
                    <Button text="Salvar alterações"
                            styleClass="btn-primary"
                            onAction="#onClickSalvar"
                            defaultButton="true"
                            HBox.hgrow="ALWAYS"
                            maxWidth="Infinity"/>
                </HBox>

            </VBox>
        </StackPane>
    </center>
</BorderPane>
