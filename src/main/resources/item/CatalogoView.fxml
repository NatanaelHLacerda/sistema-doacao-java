<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="item.CatalogoController"
            style="-fx-background-color: #f1f5f9;">

    <top>
        <HBox styleClass="app-header" alignment="CENTER_LEFT" spacing="16">
            <Label text="Sistema de Doação" styleClass="app-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="labelUsuario" styleClass="app-user-pill"/>
            <Button text="Perfil" styleClass="btn-ghost" onAction="#onClickPerfil"/>
            <Button text="Sair" styleClass="btn-ghost" onAction="#onClickSair"/>
        </HBox>
    </top>

    <center>
        <VBox styleClass="page-bg" spacing="16">

            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="2">
                    <Label text="Catálogo de Doações" styleClass="h1"/>
                    <Label fx:id="labelContador" text="0 itens" styleClass="label-muted"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="campoBusca"
                           styleClass="input-field"
                           promptText="Buscar por nome ou categoria..."
                           prefWidth="280"/>
                <Button text="+ Novo Item"
                        styleClass="btn-primary"
                        onAction="#onClickNovoItem"/>
            </HBox>

            <StackPane VBox.vgrow="ALWAYS">
                <ScrollPane fx:id="scrollGrade"
                            styleClass="marketplace-scroll"
                            fitToWidth="true"
                            hbarPolicy="NEVER">
                    <content>
                        <FlowPane fx:id="grade"
                                  styleClass="marketplace-grid"
                                  prefWrapLength="900"/>
                    </content>
                </ScrollPane>

                <VBox fx:id="estadoVazio" styleClass="empty-state"
                      alignment="CENTER" spacing="6" visible="false" managed="false">
                    <Label text="Nenhum item encontrado" styleClass="empty-state-title"/>
                    <Label text="Tente outro termo de busca ou cadastre um novo item."
                           styleClass="empty-state-caption"/>
                </VBox>
            </StackPane>

            <Label fx:id="labelFeedback" styleClass="label-success"/>

        </VBox>
    </center>
</BorderPane>
