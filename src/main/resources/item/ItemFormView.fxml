<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="item.ItemFormController"
            style="-fx-background-color: #f1f5f9;">

    <top>
        <HBox styleClass="app-header" alignment="CENTER_LEFT" spacing="16">
            <Label fx:id="labelTitulo" text="Novo Item" styleClass="app-title"/>
        </HBox>
    </top>

    <center>
        <StackPane styleClass="page-bg">
            <VBox styleClass="card" maxWidth="480" maxHeight="-Infinity"
                  spacing="20" alignment="TOP_LEFT">
                <padding>
                    <Insets top="32" right="32" bottom="32" left="32"/>
                </padding>

                <VBox spacing="6">
                    <Label text="Nome *" styleClass="caption"/>
                    <TextField fx:id="campoNome"
                               styleClass="input-field"
                               promptText="Ex: Camiseta, Livro de Java..."/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Categoria *" styleClass="caption"/>
                    <TextField fx:id="campoCategoria"
                               styleClass="input-field"
                               promptText="Ex: Roupas, Livros, Eletrônicos..."/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Quantidade *" styleClass="caption"/>
                    <TextField fx:id="campoQuantidade"
                               styleClass="input-field"
                               promptText="Ex: 1"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Descrição (opcional)" styleClass="caption"/>
                    <TextArea fx:id="campoDescricao"
                              styleClass="input-field"
                              promptText="Detalhes sobre o item..."
                              prefRowCount="3"
                              wrapText="true"/>
                </VBox>

                <Label fx:id="labelErro" styleClass="label-error" wrapText="true"/>

                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <Button text="Cancelar"
                            styleClass="btn-secondary"
                            onAction="#onClickCancelar"
                            cancelButton="true"/>
                    <Button text="Salvar"
                            styleClass="btn-primary"
                            onAction="#onClickSalvar"
                            defaultButton="true"/>
                </HBox>

            </VBox>
        </StackPane>
    </center>
</BorderPane>
